{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taxeasy",
  "version": "0.2.0",
  "identifier": "com.taxeasy.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taxeasy",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "active": true,
      "pubkey": "RWTp0LBzKNDHLw2ldkBjwhBSpMpqnF1xhl4dor7jRmIJ80+jlPPPwwN/",
      "endpoints": [
        "https://api.github.com/repos/raynaythegreat/taxeasy/releases/latest"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
